# Copy this file to .env at the repo root and fill in the values. The server loads
# .env automatically, and .env is gitignored. Never commit a real key.
#
# The Studio tools need none of this. These variables are only for the headless
# test, asset, and Open Cloud tools. See the README's "Open Cloud setup" section.

# Open Cloud API key. Required for run_luau, the headless tests, the DataStore,
# Messaging, Memory Store, platform, asset, and publish tools.
ROBLOX_OPEN_CLOUD_KEY=

# Your experience's universe and place ids (game.GameId and game.PlaceId).
# The place must be published for Open Cloud to act on it.
ROBLOX_UNIVERSE_ID=
ROBLOX_PLACE_ID=

# Your Roblox user id. Only needed for upload_asset when the asset is owned by
# you. For a group-owned asset, set ROBLOX_CREATOR_GROUP_ID instead.
ROBLOX_CREATOR_USER_ID=
# ROBLOX_CREATOR_GROUP_ID=

# Optional. The local bridge port. Defaults to 44331, which the plugin also uses.
# TRIPWIRE_BRIDGE_PORT=44331
